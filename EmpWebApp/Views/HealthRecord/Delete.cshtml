@model HealthCareApp.Models.HealthRecord

@{
    ViewBag.Title = "Delete Health Record";
}

<h2>Delete Health Record</h2>

<h4>
    Are you sure you want to delete this record?
</h4>

<hr />

<dl class="dl-horizontal">

    <dt>Patient</dt>

    <dd>
        @Model.Patient.FullName
    </dd>

    <dt>Doctor</dt>

    <dd>
        @Model.Doctor.FullName
    </dd>

    <dt>Diagnosis</dt>

    <dd>
        @Model.Diagnosis
    </dd>

</dl>

@using (Html.BeginForm())
{
    @Html.HiddenFor(
        m => m.RecordId)

    <input type="submit"
           value="Delete"
           class="btn btn-danger" />

    @Html.ActionLink(
        "Cancel",
        "Index",
        null,
        new
        {
            @class =
            "btn btn-secondary"
        })
}