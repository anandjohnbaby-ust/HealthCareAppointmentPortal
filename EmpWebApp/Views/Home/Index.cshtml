@{
    ViewBag.Title = "Healthcare Appointment Portal";
}

<div class="container mt-4">

    <div class="text-center mb-5">
        <h1 class="display-4">
            Healthcare Appointment Portal
        </h1>

        <p class="lead">
            Manage Patients, Doctors, Appointments
            and Health Records from one place.
        </p>
    </div>

    <div class="row">

        <!-- Patients -->
        <div class="col-md-3 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center d-flex flex-column">

                    <h1>👨‍⚕️</h1>

                    <h4 class="card-title">
                        Patients
                    </h4>

                    <p class="card-text flex-grow-1">
                        Register, update and manage
                        patient information.
                    </p>

                    @Html.ActionLink(
                        "Manage Patients",
                        "Index",
                        "Patient",
                        null,
                        new
                        {
                            @class =
                            "btn btn-primary"
                        })

                </div>

            </div>

        </div>

        <!-- Doctors -->
        <div class="col-md-3 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center d-flex flex-column">

                    <h1>🩺</h1>

                    <h4 class="card-title">
                        Doctors
                    </h4>

                    <p class="card-text flex-grow-1">
                        Manage doctor profiles,
                        specialisations and availability.
                    </p>

                    @Html.ActionLink(
                        "Manage Doctors",
                        "Index",
                        "Doctor",
                        null,
                        new
                        {
                            @class =
                            "btn btn-success"
                        })

                </div>

            </div>

        </div>

        <!-- Appointments -->
        <div class="col-md-3 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center d-flex flex-column">

                    <h1>📅</h1>

                    <h4 class="card-title">
                        Appointments
                    </h4>

                    <p class="card-text flex-grow-1">
                        Schedule, track and manage
                        patient appointments.
                    </p>

                    @Html.ActionLink(
                        "Manage Appointments",
                        "Index",
                        "Appointment",
                        null,
                        new
                        {
                            @class =
                            "btn btn-warning"
                        })

                </div>

            </div>

        </div>

        <!-- Health Records -->
        <div class="col-md-3 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center d-flex flex-column">

                    <h1>📋</h1>

                    <h4 class="card-title">
                        Health Records
                    </h4>

                    <p class="card-text flex-grow-1">
                        Create, update and manage
                        diagnoses, prescriptions
                        and patient records.
                    </p>

                    @Html.ActionLink(
                        "Manage Records",
                        "Index",
                        "HealthRecord",
                        null,
                        new
                        {
                            @class =
                            "btn btn-info"
                        })

                </div>

            </div>

        </div>

    </div>

</div>