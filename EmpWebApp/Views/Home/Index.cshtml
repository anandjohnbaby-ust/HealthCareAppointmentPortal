@{
    ViewBag.Title = "Healthcare Appointment Portal";
}

<div class="container">

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <h1>👨‍⚕️</h1>

                    <h4 class="card-title">
                        Patients
                    </h4>

                    <p class="card-text">
                        Register, update and manage
                        patient information.
                    </p>

                    @Html.ActionLink(
                        "Manage Patients",
                        "Index",
                        "Patient",
                        null,
                        new
                        {
                            @class =
                            "btn btn-primary"
                        })

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <h1>🩺</h1>

                    <h4 class="card-title">
                        Doctors
                    </h4>

                    <p class="card-text">
                        Manage doctor profiles,
                        specialisations and availability.
                    </p>

                    @Html.ActionLink(
                        "Manage Doctors",
                        "Index",
                        "Doctor",
                        null,
                        new
                        {
                            @class =
                            "btn btn-success"
                        })

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <h1>📅</h1>

                    <h4 class="card-title">
                        Appointments
                    </h4>

                    <p class="card-text">
                        Schedule, track and manage
                        patient appointments.
                    </p>

                    @Html.ActionLink(
                        "Manage Appointments",
                        "Index",
                        "Appointment",
                        null,
                        new
                        {
                            @class =
                            "btn btn-warning"
                        })

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <h1>📋</h1>

                    <h4 class="card-title">
                        Health Records
                    </h4>

                    <p class="card-text">
                        Create, update and manage
                        patient health records,
                        diagnoses and prescriptions.
                    </p>

                    @Html.ActionLink(
                        "Manage Records",
                        "Index",
                        "HealthRecord",
                        null,
                        new
                        {
                            @class =
                            "btn btn-info"
                        })

                </div>

            </div>

        </div>

    </div>

</div>