@using HealthCareApp.Models
@model HealthCareApp.Models.Patient

@{
    ViewBag.Title = "Edit";
}

<h2 class="text-success">Update Patient</h2>

<div class="col-6">
    @using (Html.BeginForm())
    {
        @Html.HiddenFor(m => m.PatientId)

        <div class="mb-2">
            @Html.LabelFor(m => m.FullName,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.FullName,
                new { @class = "form-control border-dark" })

            @Html.ValidationMessageFor(
                m => m.FullName,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(m => m.DateOfBirth,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.DateOfBirth,
                "{0:yyyy-MM-dd}",
                new
                {
                    @class = "form-control border-dark",
                    type = "date"
                })

            @Html.ValidationMessageFor(
                m => m.DateOfBirth,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(m => m.Gender,
                new { @class = "fw-bold" })

            <div class="form-check-inline">
                @Html.RadioButtonFor(
                    m => m.Gender,
                    Gender.Male,
                    new { @class = "form-check-input" })
                <label class="form-check-label">
                    Male
                </label>
            </div>

            <div class="form-check-inline">
                @Html.RadioButtonFor(
                    m => m.Gender,
                    Gender.Female,
                    new { @class = "form-check-input" })
                <label class="form-check-label">
                    Female
                </label>
            </div>

            <div class="form-check-inline">
                @Html.RadioButtonFor(
                    m => m.Gender,
                    Gender.Other,
                    new { @class = "form-check-input" })
                <label class="form-check-label">
                    Other
                </label>
            </div>
        </div>

        <div class="mb-2">
            @Html.LabelFor(m => m.PhoneNumber,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.PhoneNumber,
                new { @class = "form-control border-dark" })

            @Html.ValidationMessageFor(
                m => m.PhoneNumber,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(m => m.Email,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.Email,
                new
                {
                    @class = "form-control border-dark",
                    type = "email"
                })

            @Html.ValidationMessageFor(
                m => m.Email,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(m => m.InsuranceId,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.InsuranceId,
                new { @class = "form-control border-dark" })

            @Html.ValidationMessageFor(
                m => m.InsuranceId,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="d-flex">
            <button class="btn btn-primary me-2 w-50">
                Update Patient
            </button>

            @Html.ActionLink(
                "Cancel",
                "Index",
                null,
                new { @class = "btn btn-secondary w-50" })
        </div>
    }
</div>