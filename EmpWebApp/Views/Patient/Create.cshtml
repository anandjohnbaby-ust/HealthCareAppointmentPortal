@using HealthCareApp.Models
@model HealthCareApp.Models.Patient

@{
    ViewBag.Title = "Create";
}

<h2 class="text-success">Add Patient</h2>

<div class="col-6">
    @using (Html.BeginForm())
    {
        @Html.ValidationSummary(
            true,
            "",
            new { @class = "text-danger" })

        <div class="mb-2">
            @Html.LabelFor(m => m.FullName,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.FullName,
                new { @class = "form-control" })

            @Html.ValidationMessageFor(
                m => m.FullName,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(m => m.DateOfBirth,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.DateOfBirth,
                "{0:yyyy-MM-dd}",
                new
                {
                    @class = "form-control",
                    type = "date"
                })

            @Html.ValidationMessageFor(
                m => m.DateOfBirth,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            <label class="fw-bold">Gender</label>

            <div class="form-check-inline">
                @Html.RadioButtonFor(
                    m => m.Gender,
                    HealthCareApp.Models.Gender.Male)
                <label>Male</label>
            </div>

            <div class="form-check-inline">
                @Html.RadioButtonFor(
                    m => m.Gender,
                    HealthCareApp.Models.Gender.Female)
                <label>Female</label>
            </div>

            <div class="form-check-inline">
                @Html.RadioButtonFor(
                    m => m.Gender,
                    HealthCareApp.Models.Gender.Other)
                <label>Other</label>
            </div>

            @Html.ValidationMessageFor(
                m => m.Gender,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(
                m => m.PhoneNumber,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.PhoneNumber,
                new { @class = "form-control" })

            @Html.ValidationMessageFor(
                m => m.PhoneNumber,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(
                m => m.Email,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.Email,
                new
                {
                    @class = "form-control",
                    type = "email"
                })

            @Html.ValidationMessageFor(
                m => m.Email,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(
                m => m.InsuranceId,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.InsuranceId,
                new { @class = "form-control" })

            @Html.ValidationMessageFor(
                m => m.InsuranceId,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="d-flex">
            <button type="submit"
                    class="btn btn-primary me-2">
                Add Patient
            </button>

            @Html.ActionLink(
                "Cancel",
                "Index",
                null,
                new { @class = "btn btn-secondary" })
        </div>
    }
</div>