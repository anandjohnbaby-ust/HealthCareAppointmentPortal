@using HealthCareApp.Models
@model HealthCareApp.Models.Doctor

@{
    ViewBag.Title = "Edit";
}

<h2 class="text-success">Update Doctor</h2>

<div class="col-6">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(
            m => m.DoctorId)

        <div class="mb-2">
            @Html.LabelFor(
                m => m.FullName,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.FullName,
                new { @class = "form-control border-dark" })

            @Html.ValidationMessageFor(
                m => m.FullName,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(
                m => m.Specialisation,
                new { @class = "fw-bold" })

            @Html.EnumDropDownListFor(
                m => m.Specialisation,
                new { @class = "form-control border-dark" })

            @Html.ValidationMessageFor(
                m => m.Specialisation,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(
                m => m.YearsOfExperience,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.YearsOfExperience,
                new
                {
                    @class = "form-control border-dark",
                    type = "number"
                })

            @Html.ValidationMessageFor(
                m => m.YearsOfExperience,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-2">
            @Html.LabelFor(
                m => m.ConsultationFee,
                new { @class = "fw-bold" })

            @Html.TextBoxFor(
                m => m.ConsultationFee,
                new
                {
                    @class = "form-control border-dark",
                    type = "number",
                    step = "0.01"
                })

            @Html.ValidationMessageFor(
                m => m.ConsultationFee,
                "",
                new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            <label class="fw-bold">
                Available
            </label>

            @Html.CheckBoxFor(
                m => m.IsActive)
        </div>

        <div class="d-flex">
            <button class="btn btn-primary me-2 w-50">
                Update Doctor
            </button>

            @Html.ActionLink(
                "Cancel",
                "Index",
                null,
                new { @class = "btn btn-secondary w-50" })
        </div>
    }
</div>