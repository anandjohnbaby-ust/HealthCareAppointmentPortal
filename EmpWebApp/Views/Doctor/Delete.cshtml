@model HealthCareApp.Models.Doctor

@{
    ViewBag.Title = "Delete";
}

<h2 class="text-danger">
    Do you wish to delete the doctor?
</h2>

<div class="col-6">
    <table class="table table-striped">
        <tbody>

            <tr>
                <td>Doctor Id</td>
                <td>@Model.DoctorId</td>
            </tr>

            <tr>
                <td>Full Name</td>
                <td>@Model.FullName</td>
            </tr>

            <tr>
                <td>Specialisation</td>
                <td>@Model.Specialisation</td>
            </tr>

            <tr>
                <td>Years Of Experience</td>
                <td>@Model.YearsOfExperience</td>
            </tr>

            <tr>
                <td>Consultation Fee</td>
                <td>@Model.ConsultationFee</td>
            </tr>

            <tr>
                <td>Available</td>
                <td>
                    @(Model.IsActive
                        ? "Yes"
                        : "No")
                </td>
            </tr>

        </tbody>
    </table>

    <div class="d-flex">
        @using (Html.BeginForm(
            "Delete",
            "Doctor",
            new { id = Model.DoctorId },
            FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="btn btn-danger me-2">
                Delete
            </button>
        }

        @Html.ActionLink(
            "Cancel",
            "Index",
            null,
            new { @class = "btn btn-secondary" })
    </div>
</div>