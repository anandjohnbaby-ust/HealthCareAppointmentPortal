@using HealthCareApp.Models
@model List<HealthCareApp.Models.Doctor>

@{
    ViewBag.Title = "Search Doctors";
}

<h2 class="text-primary">
    Search Doctor By Specialisation
</h2>

@using (Html.BeginForm())
{
    <div class="mb-3">

        <label class="fw-bold">
            Specialisation
        </label>

        @Html.DropDownList(
            "specialisation",

            new SelectList(
                ViewBag.Specialisations),

            "-- Select Specialisation --",

            new
            {
                @class = "form-control"
            })

    </div>

    <button type="submit"
            class="btn btn-success">
        Search
    </button>

}

@if (Model != null)
{
    <hr />

    <table class="table table-striped table-bordered">

        <thead>
            <tr>
                <th>Doctor Id</th>
                <th>Full Name</th>
                <th>Specialisation</th>
                <th>Experience</th>
                <th>Consultation Fee</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var doctor in Model)
            {
                <tr>
                    <td>@doctor.DoctorId</td>
                    <td>@doctor.FullName</td>
                    <td>@doctor.Specialisation</td>
                    <td>@doctor.YearsOfExperience</td>
                    <td>@doctor.ConsultationFee</td>

                    <td>
                        @Html.ActionLink(
                            "Edit",
                            "Edit",
                            "Doctor",
                            new
                            {
                                id = doctor.DoctorId
                            },
                            new
                            {
                                @class = "btn btn-warning btn-sm me-2"
                            })

                        @Html.ActionLink(
                            "Delete",
                            "Delete",
                            "Doctor",
                            new
                            {
                                id = doctor.DoctorId
                            },
                            new
                            {
                                @class = "btn btn-danger btn-sm"
                            })
                    </td>
                </tr>
            }

        </tbody>

    </table>
}