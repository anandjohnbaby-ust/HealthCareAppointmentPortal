@model List<HealthCareApp.Models.Appointment>

@{
    ViewBag.Title = "Appointments";
}

<h2 class="text-primary">
    Appointment Details
</h2>

@Html.ActionLink(
"Book Appointment",
"Create",
null,
new
{
@class =
"btn btn-primary mb-3"
})

<table class="table table-striped table-bordered">

    <thead>
        <tr>
            <th>Id</th>
            <th>Patient</th>
            <th>Doctor</th>
            <th>Date</th>
            <th>Time</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.AppointmentId</td>

                <td>
                    @(item.Patient?.FullName)
                </td>

                <td>
                    @(item.Doctor?.FullName)
                </td>

                <td>
                    @item.ScheduledDate.ToString("dd-MM-yyyy")
                </td>

                <td>
                    @item.TimeSlot
                </td>

                <td>
                    @item.Status
                </td>

                <td>

                    @if (item.Status ==
                        HealthCareApp.Enums.AppointmentStatus.Pending)
                    {
                        @Html.ActionLink(
                            "Confirm",
                            "Confirm",
                            new
                            {
                                id = item.AppointmentId
                            },
                            new
                            {
                                @class =
                                "btn btn-success btn-sm me-1"
                            })
                    }

                    @if (item.Status ==
                        HealthCareApp.Enums.AppointmentStatus.Confirmed)
                    {
                        @Html.ActionLink(
                            "Complete",
                            "Complete",
                            new
                            {
                                id = item.AppointmentId
                            },
                            new
                            {
                                @class =
                                "btn btn-info btn-sm me-1"
                            })
                    }

                    @if (item.Status !=
                        HealthCareApp.Enums.AppointmentStatus.Completed
                        &&
                        item.Status !=
                        HealthCareApp.Enums.AppointmentStatus.Cancelled)
                    {
                        @Html.ActionLink(
                            "Cancel",
                            "Cancel",
                            new
                            {
                                id = item.AppointmentId
                            },
                            new
                            {
                                @class =
                                "btn btn-warning btn-sm me-1"
                            })
                    }

                    @Html.ActionLink(
                        "Edit",
                        "Edit",
                        new
                        {
                            id =
                            item.AppointmentId
                        },
                        new
                        {
                            @class =
                            "btn btn-outline-primary btn-sm me-1"
                        })

                    @Html.ActionLink(
                        "Delete",
                        "Delete",
                        new
                        {
                            id =
                            item.AppointmentId
                        },
                        new
                        {
                            @class =
                            "btn btn-outline-danger btn-sm"
                        })

                </td>

            </tr>
        }

    </tbody>

</table>
