@model HealthCareApp.Models.Appointment

<h2 class="text-success">
    Book Appointment
</h2>

@using (Html.BeginForm())
{
    <div class="mb-2">

        <label>Patient</label>

        @Html.DropDownListFor(
            m => m.PatientId,
            (SelectList)ViewBag.Patients,
            "-- Select Patient --",
            new
            {
                @class =
                "form-control"
            })

    </div>

    <div class="mb-2">

        <label>Doctor</label>

        @Html.DropDownListFor(
            m => m.DoctorId,
            (SelectList)ViewBag.Doctors,
            "-- Select Doctor --",
            new
            {
                @class =
                "form-control"
            })

    </div>

    <div class="mb-2">

        @Html.LabelFor(
            m => m.ScheduledDate)

        @Html.TextBoxFor(
            m => m.ScheduledDate,
            "{0:yyyy-MM-dd}",
            new
            {
                type = "date",
                @class =
                "form-control"
            })

    </div>

    <div class="mb-2">

        @Html.LabelFor(
            m => m.TimeSlot)

        @Html.TextBoxFor(
            m => m.TimeSlot,
            new
            {
                @class =
                "form-control"
            })

    </div>

    <button class="btn btn-primary">
        Book Appointment
    </button>
}